# Production .env — used by docker-compose.prod.yml on the EC2 instance.
# Copy to .env on the server and fill in real values.

# Your domain (apex only; wildcard is implicit)
DOMAIN=deployit.example.com
ACME_EMAIL=you@example.com

# Cloudflare API token with Zone:Read + DNS:Edit for the DOMAIN.
# Used by Caddy for DNS-01 challenge to fetch a wildcard SSL cert.
CLOUDFLARE_API_TOKEN=

# Postgres — pick a strong password, openssl rand -hex 24
POSTGRES_PASSWORD=

# GitHub OAuth — register at https://github.com/settings/developers
# Authorization callback URL: https://DOMAIN/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# openssl rand -hex 32  (twice — different values)
SESSION_SECRET=
ENCRYPTION_KEY=

# Optional — for AI error explainer (Week 8)
ANTHROPIC_API_KEY=
